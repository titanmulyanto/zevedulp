{
    "name": "titanmulyanto/zevedulp",
    "description": "Landing Page Zevedu Academy - CodeIgniter 4 + Tailwind CSS",
    "license": "MIT",
    "type": "project",
    "homepage": "https://github.com/titanmulyanto/zevedulp",
    "require": {
        "php": "^8.2",
        "ext-intl": "*",
        "ext-mbstring": "*",
        "codeigniter4/framework": "^4.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app",
            "Config\\": "app/Config"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
